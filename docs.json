{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "CurrentClient | Help Center",
  "colors": {
    "primary": "#3b82f6",
    "light": "#60a5fa",
    "dark": "#1d4ed8"
  },
  "favicon": "/favicon.ico",
  "fonts": {
    "family": "Airbnb Cereal",
    "source": "https://static.currentclient.com/v1/fonts/AirbnbCerealBook.woff",
    "format": "woff",
    "heading": {
      "family": "Airbnb Cereal",
      "weight": 700,
      "source": "https://static.currentclient.com/v1/fonts/AirbnbCerealBold.woff",
      "format": "woff"
    },
    "body": {
      "family": "Airbnb Cereal",
      "weight": 400,
      "source": "https://static.currentclient.com/v1/fonts/AirbnbCerealMedium.woff",
      "format": "woff"
    }
  },
  "navigation": {
    "pages": ["index"]
  },
  "redirects": [
    {
      "source": "/:slug+",
      "destination": "/"
    }
  ],
  "logo": {
    "light": "/logo/cc-full-black.png",
    "dark": "/logo/cc-full-white.png"
  }
